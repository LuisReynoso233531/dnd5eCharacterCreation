+import 'package:flutter/material.dart';
+
+import '../../../../utils/app_theme.dart';
+import '../../../../view_models/character/character_view_model.dart';
+import '../section_title.dart';
+
+class DwarfToolProficiencySection extends StatelessWidget {
+  const DwarfToolProficiencySection({
+    super.key,
+    required this.viewModel,
+  });
+
+  final CreateCharacterViewModel viewModel;
+
+  @override
+  Widget build(BuildContext context) {
+    if (!viewModel.requiresRacialToolProficiencyChoice) {
+      return const SizedBox.shrink();
+    }
+
+    final selected = viewModel.selectedRacialToolProficiency;
+
+    return Column(
+      crossAxisAlignment: CrossAxisAlignment.start,
+      children: [
+        sectionTitle('Dwarven Tool Proficiency'),
+        const SizedBox(height: 6),
+        Text(
+          "Choose one artisan's tool proficiency granted by your dwarf race.",
+          style: Theme.of(context).textTheme.bodySmall?.copyWith(
+            color: context.dndColors.mutedText,
+          ),
+        ),
+        const SizedBox(height: 12),
+        DropdownButtonFormField<String>(
+          key: ValueKey('dwarf-tool-$selected'),
+          initialValue: selected,
+          isExpanded: true,
+          decoration: InputDecoration(
+            labelText: 'Tool proficiency',
+            prefixIcon: const Icon(Icons.handyman_outlined),
+            helperText: selected == null
+                ? 'Required before continuing'
+                : 'Added to Tools & Kits and to the character sheet',
+          ),
+          items: CreateCharacterViewModel.dwarfToolProficiencyOptions
+              .map(
+                (tool) => DropdownMenuItem<String>(
+                  value: tool,
+                  child: Text(tool),
+                ),
+              )
+              .toList(),
+          onChanged: viewModel.selectRacialToolProficiency,
+        ),
+        if (selected != null) ...[
+          const SizedBox(height: 10),
+          Container(
+            width: double.infinity,
+            padding: const EdgeInsets.all(12),
+            decoration: BoxDecoration(
+              color: context.dndColors.successContainer,
+              borderRadius: BorderRadius.circular(10),
+              border: Border.all(
+                color: context.dndColors.success.withValues(alpha: 0.45),
+              ),
+            ),
+            child: Row(
+              children: [
+                Icon(
+                  Icons.check_circle_outline,
+                  color: context.dndColors.success,
+                  size: 20,
+                ),
+                const SizedBox(width: 10),
+                Expanded(
+                  child: Text(
+                    'Proficient with $selected',
+                    style: TextStyle(
+                      color: context.dndColors.onSuccessContainer,
+                      fontWeight: FontWeight.w600,
+                    ),
+                  ),
+                ),
+              ],
+            ),
+          ),
+        ],
+      ],
+    );
+  }
+}
